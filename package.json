{
  "name": "wifiman",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "dotenv -- pnpm --parallel --filter @wifiman/api --filter @wifiman/web dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "db:generate": "pnpm --filter @wifiman/api db:generate",
    "db:migrate": "pnpm --filter @wifiman/api db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
